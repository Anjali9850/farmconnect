# ============================================================
#  FarmConnect – .htaccess
#  Apache 2.4 compatible (XAMPP Windows)
# ============================================================

# Disable directory listing
Options -Indexes

# Enable mod_rewrite for clean URLs (if needed later)
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Block direct access to sensitive files
<FilesMatch "\.(sql|env|log|ini)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# UTF-8 charset default
AddDefaultCharset UTF-8
